# Agent System Environment Configuration
# Copy this file to .env and fill in your values

# ===================
# DATABASE
# ===================
DATABASE_URL=postgresql+asyncpg://agent:agent_secret@localhost:5432/agent_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ===================
# REDIS
# ===================
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# ===================
# KAFKA
# ===================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=agent-system

# ===================
# LLM PROVIDERS
# ===================
# Anthropic Claude API key
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key
OPENAI_API_KEY=sk-...

# Default LLM provider (anthropic or openai)
DEFAULT_LLM_PROVIDER=openai

# Default model per provider
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-5
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# LLM timeout (seconds)
LLM_TIMEOUT=120

# ===================
# AUTHENTICATION
# ===================
# JWT secret for user token signing (CHANGE IN PRODUCTION!)
JWT_SECRET=change_in_production_use_32_plus_chars

# JWT algorithm
JWT_ALGORITHM=HS256

# JWT token expiration in seconds (default: 1 hour)
JWT_EXPIRATION=3600

# Master admin key for platform owner (CHANGE IN PRODUCTION!)
# This key allows creating tenants and managing the entire platform
MASTER_ADMIN_KEY=change_in_production_use_long_random_string_min_32_chars

# Internal JWT secret for service-to-service authentication (CHANGE IN PRODUCTION!)
# This must be different from JWT_SECRET and is used for Kafka payload authentication
INTERNAL_JWT_SECRET=change_in_production_internal_secret_different_from_jwt_min_32_chars

# One-Time Token TTL for stream connections (10-300 seconds)
OTT_TTL_SECONDS=60

# One-Time Token TTL for file download links (60-3600 seconds). Enables openable links in chat.
FILE_DOWNLOAD_OTT_TTL_SECONDS=300

# ===================
# BILLING
# ===================
# Enable billing pre-checks on job creation (default: false)
ENABLE_BILLING_CHECKS=false

# Default credit balance for new tenants in microdollars (100,000,000 = $100.00)
DEFAULT_CREDIT_BALANCE_MICROS=100000000

# ===================
# RATE LIMITING
# ===================
# Default requests per minute per tenant
RATE_LIMIT_RPM=60

# Default tokens per minute per tenant
RATE_LIMIT_TPM=100000

# ===================
# ORCHESTRATOR
# ===================
# Enable suspend/resume architecture (set to false for rollback to polling)
ENABLE_SUSPEND_RESUME=true

# ===================
# TOOL WORKERS
# ===================
# Web search provider (duckduckgo or brave)
WEB_SEARCH_PROVIDER=brave

# Brave Search API key (optional, only if WEB_SEARCH_PROVIDER=brave)
# Get yours at: https://brave.com/search/api/
BRAVE_API_KEY=

# Code execution settings
CODE_EXECUTOR_ENABLED=true
CODE_EXECUTOR_TIMEOUT=30
CODE_EXECUTOR_MEMORY_LIMIT_MB=256

# ===================
# FILE STORAGE
# ===================
# Enable persisting uploaded files to disk (in addition to Redis)
FILE_STORAGE_PERSIST=false

# Directory for persistent file storage (used if FILE_STORAGE_PERSIST=true)
FILE_STORAGE_PATH=./file_uploads

# ===================
# KNOWLEDGE BASE / VECTOR SEARCH
# ===================
# Milvus vector database connection
MILVUS_HOST=localhost
MILVUS_PORT=19530

# OpenAI embeddings (uses OPENAI_API_KEY from LLM PROVIDERS section)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Knowledge base settings
KB_MAX_CONTENT_LENGTH=50000

# ===================
# ARCHIVER
# ===================
# Stream retention in hours (default 24)
STREAM_RETENTION_HOURS=24

# Cleanup interval in seconds (default 3600 = 1 hour)
ARCHIVER_CLEANUP_INTERVAL=3600

# Batch settings
ARCHIVER_BATCH_SIZE=100
ARCHIVER_FLUSH_INTERVAL=5

# ===================
# SERVICE PORTS
# ===================
API_GATEWAY_PORT=8000
STREAM_EDGE_PORT=8001
WEBSOCKET_GATEWAY_PORT=8002
FRONTEND_PORT=3000

# ===================
# LIVE ASSISTANT
# ===================
# Deepgram STT API key (required for voice chat)
# Get yours at: https://console.deepgram.com/
DEEPGRAM_API_KEY=

# ElevenLabs TTS API key (required for voice chat)
# Get yours at: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# Default TTS voice ID (Rachel is a good default)
# See https://elevenlabs.io/docs/speech-synthesis/voices
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Live session settings
LIVE_SESSION_TIMEOUT_SECONDS=3600
LIVE_SESSION_MAX_PER_TENANT=10

# ===================
# CORS
# ===================
# Allowed CORS origins (comma-separated list or "*" for development)
# In production, restrict this to your frontend domains.
# Example: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=*

# ===================
# LOGGING
# ===================
LOG_LEVEL=INFO
LOG_FORMAT=json # json or text

# ===================
# ENVIRONMENT
# ===================
ENVIRONMENT=development # development, staging, production
DEBUG=true

# ===================
# SERVICE HOSTS
# ===================
API_HOST=localhost # API host
STREAM_EDGE_URL=http://localhost:8001

# ===================
# AUTH BROKER (Optional, for testing)
# ===================
GATEWAY_URL=http://localhost:8000 # Gateway URL

# ===================
# TEST
# ===================
TEST_API_BASE_URL=http://localhost:8000
RUN_INTEGRATION_TESTS=false
TENANT_API_KEY= # Tenant API key
USER_ID= # User ID

# ===================
# PGADMIN
# ===================
PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=

# ===================
# OTHER SETTINGS
# ===================
VITE_AUTH_BROKER_URL=http://localhost:8003
VITE_API_BASE_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8002/ws
POSTGRES_PORT=5432
REDIS_PORT=6379
ZOOKEEPER_PORT=2181
KAFKA_PORT=9092
KAFKA_ADVERTISED_PORT=29092
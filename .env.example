# Agent System Environment Configuration
# Copy this file to .env and fill in your values

# ===================
# DATABASE
# ===================
DATABASE_URL=postgresql+asyncpg://agent:agent_secret@localhost:5432/agent_db

# ===================
# REDIS
# ===================
REDIS_URL=redis://localhost:6379/0

# ===================
# KAFKA
# ===================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ===================
# LLM PROVIDERS
# ===================
# Anthropic Claude API key
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key
OPENAI_API_KEY=sk-...

# Default LLM provider (anthropic or openai)
DEFAULT_LLM_PROVIDER=openai

# Default model per provider
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ===================
# AUTHENTICATION
# ===================
# JWT secret for user token signing (CHANGE IN PRODUCTION!)
JWT_SECRET=change_in_production_use_32_plus_chars

# JWT token expiration in seconds (default: 1 hour)
JWT_EXPIRATION=3600

# Master admin key for platform owner (CHANGE IN PRODUCTION!)
# This key allows creating tenants and managing the entire platform
MASTER_ADMIN_KEY=change_in_production_use_long_random_string_min_32_chars

# Internal JWT secret for service-to-service authentication (CHANGE IN PRODUCTION!)
# This must be different from JWT_SECRET and is used for Kafka payload authentication
INTERNAL_JWT_SECRET=change_in_production_internal_secret_different_from_jwt_min_32_chars

# ===================
# BILLING
# ===================
# Enable billing pre-checks on job creation (default: false)
ENABLE_BILLING_CHECKS=false

# Default credit balance for new tenants in microdollars (100,000,000 = $100.00)
DEFAULT_CREDIT_BALANCE_MICROS=100000000

# ===================
# RATE LIMITING
# ===================
# Default requests per minute per tenant
RATE_LIMIT_RPM=60

# Default tokens per minute per tenant
RATE_LIMIT_TPM=100000

# ===================
# ORCHESTRATOR
# ===================
# Enable suspend/resume architecture (set to false for rollback to polling)
ENABLE_SUSPEND_RESUME=true

# ===================
# SERVICE PORTS
# ===================
API_GATEWAY_PORT=8000
STREAM_EDGE_PORT=8001
FRONTEND_PORT=3000

# ===================
# LOGGING
# ===================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===================
# ENVIRONMENT
# ===================
ENVIRONMENT=development
DEBUG=true

# ===================
# SERVICE HOSTS
# ===================
API_HOST=localhost

# ===================
# TEST
# ===================
TEST_API_BASE_URL=http://94.16.119.44:8000
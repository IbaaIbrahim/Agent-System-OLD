# Agent System Environment Configuration
# Copy this file to .env and fill in your values

# ===================
# DATABASE
# ===================
DATABASE_URL=postgresql+asyncpg://agent:agent_secret@localhost:5432/agent_db

# ===================
# REDIS
# ===================
REDIS_URL=redis://localhost:6379/0

# ===================
# KAFKA
# ===================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ===================
# LLM PROVIDERS
# ===================
# Anthropic Claude API key
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key
OPENAI_API_KEY=sk-...

# Default LLM provider (anthropic or openai)
DEFAULT_LLM_PROVIDER=anthropic

# Default model per provider
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514
OPENAI_DEFAULT_MODEL=gpt-4-turbo-preview

# ===================
# AUTHENTICATION
# ===================
# JWT secret for token signing (CHANGE IN PRODUCTION!)
JWT_SECRET=change_in_production_use_32_plus_chars

# JWT token expiration in seconds (default: 1 hour)
JWT_EXPIRATION=3600

# ===================
# RATE LIMITING
# ===================
# Default requests per minute per tenant
RATE_LIMIT_RPM=60

# Default tokens per minute per tenant
RATE_LIMIT_TPM=100000

# ===================
# SERVICE PORTS
# ===================
API_GATEWAY_PORT=8000
STREAM_EDGE_PORT=8001
FRONTEND_PORT=3000

# ===================
# LOGGING
# ===================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===================
# ENVIRONMENT
# ===================
ENVIRONMENT=development
DEBUG=false

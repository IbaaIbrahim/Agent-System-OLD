{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Orchestrator",
            "type": "debugpy",
            "request": "launch",
            "module": "services.orchestrator.src.main",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Orchestrator (Watch Mode)",
            "type": "debugpy",
            "request": "launch",
            "module": "watchfiles",
            "args": [
                "--ignore-paths",
                ".cursor",
                "${command:python.interpreterPath} -m services.orchestrator.src.main"
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "subProcess": true
        },
        {
            "name": "API Gateway",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": ["services.api-gateway.src.main:app", "--reload", "--port", "8000", "--host", "localhost"],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
